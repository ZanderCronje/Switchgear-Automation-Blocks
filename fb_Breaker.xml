          <BodyContent xsi:type="ST">
            <ST>{region 'Defaults and Edge Detection'}
    //Breaker Mode
    CASE Breaker.Mode OF
        BreakerMode#MANUAL:
            xOpenRequestActive  := Breaker.HMI.xOpenRequest;
            xCloseRequestActive := Breaker.HMI.xCloseRequest;
            xResetRequestActive := Breaker.HMI.xResetRequest;
            xControlAllowed     := TRUE;
    
        BreakerMode#AUTO:
            xOpenRequestActive  := xAUTO_OpenRequest;
            xCloseRequestActive := xAUTO_CloseRequest;
            xResetRequestActive := xAUTO_ResetRequest;
            xControlAllowed     := TRUE;
    
        BreakerMode#EXTERNAL:
            xOpenRequestActive  := FALSE;
            xCloseRequestActive := FALSE;
            xResetRequestActive := FALSE;
            xControlAllowed     := FALSE;
    END_CASE;
    
    //Edge Detection
    rtOpenReq(CLK := xOpenRequestActive);
    rtCloseReq(CLK := xCloseRequestActive);
    rtReset(CLK := xResetRequestActive);
    
    //Reset Commands
    IF Breaker.Mode = BreakerMode#MANUAL THEN
        Breaker.HMI.xOpenRequest    := FALSE;
        Breaker.HMI.xCloseRequest   := FALSE;
        Breaker.HMI.xResetRequest   := FALSE;
    END_IF;
    
{endregion}

{region 'Feedback Evaluation'}
    //Breaker status based on feedback
    xIsOpen         := Breaker.DI.xOpened AND NOT Breaker.DI.xClosed;
    xIsClosed       := Breaker.DI.xClosed AND NOT Breaker.DI.xOpened;
    xIsTripped      := Breaker.DI.xTripped;
    xIsInvalid      := Breaker.DI.xOpened AND Breaker.DI.xClosed;
    
{endregion}

{region 'Permissions'}
    //External Mode?
    xControlAllowed := Breaker.Mode &lt;&gt; BreakerMode#EXTERNAL;
    //Can the Breaker be Opened?
    xCanOpen :=     xEnable
                    AND xControlAllowed
                    AND Breaker.Status.xRemote
                    AND NOT Breaker.Interlocks.xOpenBlocked
                    AND NOT xIsInvalid
                    AND NOT Breaker.Status.xFault;
    //Can the Breaker be Closed?
    xCanClose :=    xEnable
                    AND xControlAllowed
                    AND Breaker.Status.xRemote
                    AND NOT Breaker.Interlocks.xCloseBlocked
                    AND Breaker.DI.xReadyToClose
                    AND NOT xIsTripped
                    AND NOT xIsInvalid
                    AND NOT Breaker.Status.xFault;
{endregion}

</ST>
          </BodyContent>
          <BodyContent xsi:type="ST">
            <ST>{region 'FSM Setup'}
    BreakerCurrentState := Breaker.State;
    BreakerNextState    := BreakerCurrentState;
{endregion}

{region 'Breaker FSM'}
    IF NOT xEnable THEN
        BreakerNextState    := BreakerState#UNKNOWN;
        xOpenPulseActive    := FALSE;
        xClosePulseActive   := FALSE;
    
    ELSIF xIsInvalid THEN
        BreakerNextState        := BreakerState#INVALID;
        xOpenPulseActive        := FALSE;
        xClosePulseActive       := FALSE;
        Breaker.Status.xFault   := TRUE;
        Breaker.Status.xAlarm   := TRUE;
    
    ELSIF xIsTripped THEN
        BreakerNextState        := BreakerState#TRIPPED;
        xOpenPulseActive        := FALSE;
        xClosePulseActive       := FALSE;
        Breaker.Status.xAlarm   := TRUE;
    
    ELSE
        CASE BreakerCurrentState OF
            BreakerState#UNKNOWN:    // derive OPEN/CLOSED/UNKNOWN            
            {region 'Unknown Breaker State'}
                        xOpenPulseActive    := FALSE;
                        xClosePulseActive   := FALSE;
                        
                        //Is the Breaker Open or Closed?
                        IF xIsOpen THEN
                            BreakerNextState := BreakerState#OPEN;
                        ELSIF xIsClosed THEN
                            BreakerNextState := BreakerState#CLOSED;
                        ELSE
                            BreakerNextState := BreakerState#UNKNOWN;
                        END_IF;
            {endregion}
            BreakerState#OPEN:       // close request -&gt; CLOSING           
            {region 'Open Breaker State'}
                        xOpenPulseActive := FALSE;
                        //Is Breaker still Open?
                        IF NOT xIsOpen THEN
                            BreakerNextState := BreakerState#UNKNOWN;
                        //Close the Breaker?
                        ELSIF rtCloseReq.Q AND xCanClose THEN
                            BreakerNextState := BreakerState#CLOSING;
                            xClosePulseActive := TRUE;
                        END_IF;
            {endregion}
            BreakerState#CLOSED:     // open request -&gt; OPENING            
            {region 'Closed Breaker State'}
                        xClosePulseActive := FALSE;
                        //Is Breaker still Closed?
                        IF NOT xIsClosed THEN
                            BreakerNextState := BreakerState#UNKNOWN;
                        //Open The Breaker?
                        ELSIF rtOpenReq.Q AND xCanOpen THEN
                            BreakerNextState := BreakerState#OPENING;
                            xOpenPulseActive := TRUE;
                        END_IF;
            {endregion}
            BreakerState#OPENING:    // open feedback -&gt; OPEN, timeout -&gt; FAULT
            {region 'Breaker Opening'}
                        //Did Breaker Open?
                        IF xIsOpen THEN
                            BreakerNextState            := BreakerState#OPEN;
                            xOpenPulseActive            := FALSE;
                            Breaker.Status.xCmdFailed   := FALSE;
                        //Breaker didnt Open    
                        ELSIF tonOpenTimeout.Q THEN
                            BreakerNextState            := BreakerState#FAULT;
                            xOpenPulseActive            := FALSE;
                            Breaker.Status.xCmdFailed   := TRUE;
                            Breaker.Status.xFault       := TRUE;
                            Breaker.Status.xAlarm       := TRUE;
                        END_IF;        
            {endregion}
            BreakerState#CLOSING:    // closed feedback -&gt; CLOSED, timeout -&gt; FAULT
            {region 'Breaker Closing'}
                        //Did Breaker Close?
                        IF xIsClosed THEN
                            BreakerNextState            := BreakerState#CLOSED;
                            xClosePulseActive           := FALSE;
                            Breaker.Status.xCmdFailed   := FALSE;
                        //Breaker Didnt Close
                        ELSIF tonCloseTimeout.Q THEN
                            BreakerNextState            := BreakerState#FAULT;
                            xClosePulseActive           := FALSE;
                            Breaker.Status.xCmdFailed   := TRUE;
                            Breaker.Status.xFault       := TRUE;
                            Breaker.Status.xAlarm       := TRUE;
                        END_IF;        
            {endregion}
            BreakerState#TRIPPED:    // reset after trip clears -&gt; UNKNOWN
            {region 'Breaker Tripped'}
                        xOpenPulseActive    := FALSE;
                        xClosePulseActive   := FALSE;
                        //Reset Breaker?
                        IF xResetRequestActive AND NOT xIsTripped THEN
                            Breaker.Status.xAlarm := FALSE;
                            BreakerNextState := BreakerState#UNKNOWN;
                        END_IF;
            
            {endregion}
            BreakerState#FAULT:      // reset -&gt; UNKNOWN
            {region 'Breaker in Fault'}
                        xOpenPulseActive    := FALSE;
                        xClosePulseActive   := FALSE;
                        //Try to Reset the Internal Fault?
                        IF rtReset.Q THEN
                            Breaker.Status.xFault       := FALSE;
                            Breaker.Status.xAlarm       := FALSE;
                            Breaker.Status.xCmdFailed   := FALSE;
                            BreakerNextState            := BreakerState#UNKNOWN;
                        END_IF;
            {endregion}
            BreakerState#INVALID:    // reset after feedback normalizes -&gt; UNKNOWN
            {region 'Invalid Breaker State'}
                        xOpenPulseActive    := FALSE;
                        xClosePulseActive   := FALSE;
                        //Try to Reset the Internal Fault?
                        IF xResetRequestActive AND NOT xIsInvalid THEN
                            Breaker.Status.xFault := FALSE;
                            Breaker.Status.xAlarm := FALSE;
                            BreakerNextState := BreakerState#UNKNOWN;
                        END_IF; 
            {endregion}
        END_CASE;
    END_IF;
{endregion}</ST>
          </BodyContent>
          <BodyContent xsi:type="ST">
            <ST>  
{region 'Timer Control'}  
   tonOpenPulse(
        IN := xOpenPulseActive,
        PT := tOpenPulse
    );
    tonClosePulse(
        IN := xClosePulseActive,
        PT := tClosePulse
    );
    tonOpenTimeout(
        IN := BreakerNextState = BreakerState#OPENING,
        PT := tOpenTimeout
    );
    tonCloseTimeout(
        IN := BreakerNextState = BreakerState#CLOSING,
        PT := tCloseTimeout
    );
{endregion}  

{region 'Pulse Control'}
    IF tonOpenPulse.Q OR Breaker.Interlocks.xOpenBlocked OR NOT xControlAllowed THEN
        xOpenPulseActive := FALSE;
    END_IF;
    
    IF tonClosePulse.Q OR Breaker.Interlocks.xCloseBlocked OR NOT xControlAllowed THEN
        xClosePulseActive := FALSE;
    END_IF;
{endregion}  
             </ST>
          </BodyContent>
          <BodyContent xsi:type="ST">
            <ST>  
{region 'Set State Variables'}
    Breaker.State                   :=  BreakerNextState;
    CASE Breaker.State OF
        BreakerState#UNKNOWN:    Breaker.iState := 0;
        BreakerState#OPEN:       Breaker.iState := 1;
        BreakerState#CLOSED:     Breaker.iState := 2;
        BreakerState#TRIPPED:    Breaker.iState := 3;
        BreakerState#OPENING:    Breaker.iState := 4;
        BreakerState#CLOSING:    Breaker.iState := 5;
        BreakerState#FAULT:      Breaker.iState := 6;
        BreakerState#INVALID:    Breaker.iState := 7;
    ELSE
        Breaker.iState := 0;
    END_CASE;
    CASE Breaker.Mode OF
        BreakerMode#MANUAL:     Breaker.iMode := 0;
        BreakerMode#AUTO:       Breaker.iMode := 1;
        BreakerMode#EXTERNAL:   Breaker.iMode := 2;
    ELSE
        Breaker.iMode := 0;
    END_CASE;
{endregion} 

{region 'Set Commands'}
    Breaker.DQ.xcmd_Open            :=  xOpenPulseActive AND NOT tonOpenPulse.Q;
    Breaker.DQ.xcmd_Close           :=  xClosePulseActive AND NOT tonClosePulse.Q;
{endregion}    

{region 'Set Statuses'}
    Breaker.Status.xInvalidState    :=  xIsInvalid;
    Breaker.Status.xCmdBusy         :=  (BreakerNextState  = BreakerState#OPENING) OR (BreakerNextState  = BreakerState#CLOSING);
    Breaker.Status.xAvailable       :=  xCanOpen OR xCanClose;
{endregion}    
    </ST>
          </BodyContent>
        </MainBody>
